#!/bin/bash
set -o pipefail

# Читаем конфигурацию из файла (не хранится в git).
# Скопируйте backup.conf.example → /etc/home-router-panel/backup.conf
# и заполните своими значениями.
CONF_FILE="/etc/home-router-panel/backup.conf"
if [[ -f "$CONF_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$CONF_FILE"
fi

MAC_USER="${BACKUP_MAC_USER:?BACKUP_MAC_USER not set in $CONF_FILE}"
MAC_HOST="${BACKUP_MAC_HOST:?BACKUP_MAC_HOST not set in $CONF_FILE}"
MAC_SSH_KEY="${BACKUP_MAC_SSH_KEY:?BACKUP_MAC_SSH_KEY not set in $CONF_FILE}"
BACKUP_NAME="homerouter-$(date +%Y-%m-%d_%H-%M-%S).tar.gz"

exec /usr/bin/tar \
  --xattrs \
  --acls \
  --numeric-owner \
  --ignore-failed-read \
  --warning=no-file-changed \
  -czpf - \
  --exclude="/home/meteopavel/router-backups" \
  --exclude="/home/meteopavel/.cache" \
  --exclude="/home/meteopavel/.local/share/Trash" \
  --exclude="/tmp" \
  --exclude="/var/tmp" \
  --exclude="/var/cache" \
  --exclude="/var/log/*.log" \
  /etc \
  /home/meteopavel \
  /opt \
  /var/lib \
  /var/spool \
  /var/backups \
  /root \
  /usr/local \
  /srv \
  /boot \
| /usr/bin/ssh -i "$MAC_SSH_KEY" -o BatchMode=yes -o StrictHostKeyChecking=accept-new \
  -o UserKnownHostsFile=/home/meteopavel/.ssh/known_hosts "$MAC_USER@$MAC_HOST" \
  "mkdir -p ~/router-backups && cat > ~/router-backups/$BACKUP_NAME"
